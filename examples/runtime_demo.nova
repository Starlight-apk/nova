#!/bin/bash
#===============================================================================
# NovaScript Runtime Demo
# 展示类似 Python/Node.js 的强大功能
#===============================================================================

echo "========================================"
echo "  NovaScript Runtime v2.0 Demo"
echo "========================================"
echo ""

#-------------------------------------------------------------------------------
# 1. 日志系统
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[1] 日志系统\033[0m"
nova_log_info "这是一个信息日志"
nova_log_warn "这是一个警告日志"
nova_log_error "这是一个错误日志"
echo ""

#-------------------------------------------------------------------------------
# 2. 变量管理
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[2] 变量管理\033[0m"
nova_var_set "username" "Alice"
nova_var_set "age" "25"
nova_var_set "score" "95.5"

echo "Username: $(nova_var_get username)"
echo "Age: $(nova_var_get age)"
echo "Score: $(nova_var_get score)"
echo ""

#-------------------------------------------------------------------------------
# 3. 类型检测
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[3] 类型检测\033[0m"
echo "Type of '42': $(nova_type_of 42)"
echo "Type of '3.14': $(nova_type_of 3.14)"
echo "Type of 'hello': $(nova_type_of hello)"
echo "Type of 'true': $(nova_type_of true)"
echo ""

#-------------------------------------------------------------------------------
# 4. 字符串操作
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[4] 字符串操作\033[0m"
text="Hello, NovaScript!"
echo "Original: $text"
echo "Upper: $(nova_str_upper "$text")"
echo "Lower: $(nova_str_lower "$text")"
echo "Length: $(nova_str_len "$text")"
echo "Substring(0-5): $(nova_str_substr "$text" 0 5)"
echo "Contains 'Nova': $(nova_str_contains "$text" "Nova")"
echo "Repeat 3x: $(nova_str_repeat "Hi " 3)"
echo ""

#-------------------------------------------------------------------------------
# 5. 数学运算
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[5] 数学运算\033[0m"
echo "10 + 5 = $(nova_math_add 10 5)"
echo "10 - 5 = $(nova_math_sub 10 5)"
echo "10 * 5 = $(nova_math_mul 10 5)"
echo "10 / 3 = $(nova_math_div 10 3)"
echo "17 % 5 = $(nova_math_mod 17 5)"
echo "2^8 = $(nova_math_pow 2 8)"
echo "sqrt(16) = $(nova_math_sqrt 16)"
echo "abs(-42) = $(nova_math_abs -- -42)"
echo "PI = $(nova_math_pi)"
echo ""

#-------------------------------------------------------------------------------
# 6. 数组操作
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[6] 数组操作\033[0m"
declare -a fruits=("apple" "banana" "cherry")
echo "Original array: ${fruits[*]}"
nova_arr_push fruits "date"
echo "After push: ${fruits[*]}"
echo "Array length: $(nova_arr_len fruits)"
echo "First element: $(nova_arr_get fruits 0)"
echo ""

#-------------------------------------------------------------------------------
# 7. 异常处理
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[7] 异常处理\033[0m"
nova_try 'echo "Try block executed"; false' 'echo "Catch block: Error caught!"' 'echo "Finally block always runs"'
echo ""

#-------------------------------------------------------------------------------
# 8. 系统信息
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[8] 系统信息\033[0m"
echo "OS: $(nova_sys_os)"
echo "Architecture: $(nova_sys_arch)"
echo "Hostname: $(nova_sys_hostname)"
echo "User: $(nova_sys_user)"
echo "PWD: $(nova_sys_pwd)"
echo "PID: $(nova_sys_pid)"
echo ""

#-------------------------------------------------------------------------------
# 9. 时间日期
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[9] 时间日期\033[0m"
echo "Timestamp: $(nova_time_now)"
echo "Today: $(nova_date_today)"
echo "ISO Format: $(nova_date_iso)"
echo "Formatted: $(nova_date_format "$(nova_time_now)" "%Y年%m月%d日 %H:%M")"
echo ""

#-------------------------------------------------------------------------------
# 10. 调试工具
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[10] 调试工具\033[0m"
nova_inspect "demo_var" "test_value"
echo ""

#-------------------------------------------------------------------------------
# 11. 函数定义和调用
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[11] 函数定义和调用\033[0m"
nova_func_define "greet" "name" 'echo "Hello, $name! Welcome to NovaScript!"'
nova_func_call "greet" "Developer"
echo ""

#-------------------------------------------------------------------------------
# 12. HTTP 请求（如果有网络）
#-------------------------------------------------------------------------------
echo -e "\033[1;36m[12] HTTP 客户端\033[0m"
if command -v curl &>/dev/null; then
    echo "Testing HTTP client..."
    # 使用本地测试或跳过
    response=$(nova_http_get "http://localhost:1" 2>&1 || true)
    if [[ -n "$response" ]]; then
        echo "HTTP client is available (curl)"
    else
        echo "HTTP client ready (no network connection for test)"
    fi
else
    echo "curl not available, HTTP client disabled"
fi
echo ""

#-------------------------------------------------------------------------------
# 总结
#-------------------------------------------------------------------------------
echo "========================================"
echo "  Demo Complete!"
echo "========================================"
echo ""
echo "NovaScript Runtime provides:"
echo "  ✓ Python-like variable management"
echo "  ✓ Node.js-style module system"
echo "  ✓ Rich string/array operations"
echo "  ✓ Exception handling (try/catch)"
echo "  ✓ Type detection"
echo "  ✓ Math functions"
echo "  ✓ HTTP client"
echo "  ✓ JSON parsing"
echo "  ✓ System information"
echo "  ✓ Logging framework"
echo ""
echo "All built on top of Bash!"
echo ""
